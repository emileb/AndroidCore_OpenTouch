<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/promo_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:background="#2b2b2b"
    android:orientation="vertical"
    android:padding="6dp">

    <!-- Header: name centered over the icon, tagline centered over the screenshots (weights mirror content row) -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/app_name_textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center_horizontal"
            android:text="App Name"
            android:textColor="#FFFFFF"
            android:textSize="17dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/app_tagline_textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="6"
            android:gravity="center_horizontal"
            android:text="Tagline"
            android:textColor="#B0B0B0"
            android:textSize="13dp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <!-- Content row: icon | screenshots (centered) | engine list. Icon and list columns are equal width. -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Left: tall icon + GET button -->
        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/app_icon_imageView"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:scaleType="fitCenter"
                app:srcCompat="@mipmap/ic_launcher" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/get_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minHeight="0dp"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:text="GET"
                android:textSize="12dp"
                app:icon="@drawable/ic_baseline_world"
                app:iconSize="16dp"
                android:theme="@style/ButtonMaterial" />
        </androidx.appcompat.widget.LinearLayoutCompat>

        <!-- Middle: two screenshots, centered in the row -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/shot_1_imageView"
            android:layout_width="0dp"
            android:layout_height="92dp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="3"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/shot_2_imageView"
            android:layout_width="0dp"
            android:layout_height="92dp"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="4dp"
            android:layout_weight="3"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter" />

        <!-- Right: bold bullet list of engines (same width as the icon column) -->
        <TextView
            android:id="@+id/engines_textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:lineSpacingMultiplier="0.95"
            android:text="• Engine"
            android:textColor="#E0E0E0"
            android:textSize="11dp"
            android:textStyle="bold" />
    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.appcompat.widget.LinearLayoutCompat>
